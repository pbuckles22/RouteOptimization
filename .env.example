# Copy to .env and fill in your keys (never commit .env).
# Google Cloud: enable Places API, then create an API key.
# Mapbox: https://account.mapbox.com/access-tokens/

MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# Optional: bias Mapbox fallback when proxy is off
# SEARCH_COUNTRY=us
# SEARCH_PROXIMITY_LNG=-122.0
# SEARCH_PROXIMITY_LAT=37.0
